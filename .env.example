# Frontend (Vite). Use in production when deploying the app.
# Example: https://shark-in.vercel.app
VITE_API_URL=https://your-api-url.onrender.com

# Backend (server). Copy to server/.env for local dev.
# JWT_SECRET=your-secret-at-least-32-chars
# FRONTEND_URL=http://localhost:5173
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
# FACEBOOK_REDIRECT_URI=http://localhost:3001/api/auth/facebook/callback
