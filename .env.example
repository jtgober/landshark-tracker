# Frontend (Vite). Use in production when deploying the app.
# Example: https://shark-in.vercel.app
VITE_API_URL=https://your-api-url.onrender.com

# Backend (server). Copy to server/.env for local dev.
#
# Persistence (e.g. 5GB disk mounted at /data):
#   DATABASE_PATH=/data/database.sqlite
# That puts the DB on /data and avatars at /data/uploads/avatars/ (same disk).
# Only set UPLOADS_DIR if you need a different uploads root than /data/uploads.
# DATABASE_PATH=/data/database.sqlite
# UPLOADS_DIR=/data/uploads
#
# JWT_SECRET=your-secret-at-least-32-chars
# FRONTEND_URL=http://localhost:5173
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
# FACEBOOK_REDIRECT_URI=http://localhost:3001/api/auth/facebook/callback
